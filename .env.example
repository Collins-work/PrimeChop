TELEGRAM_BOT_TOKEN=replace_with_botfather_token
# Local/dev: keep DB_PATH as sqlite file.
# SQLite example:
# DB_PATH=primechop.db
# Railway/prod mirror: keep SQLite primary DB_PATH and set Postgres mirror URL.
# POSTGRES_MIRROR_URL=${{Postgres.DATABASE_URL}}
DB_PATH=primechop.db
POSTGRES_MIRROR_URL=
WEBHOOK_ENABLED=false
WEBHOOK_BASE_URL=
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_LISTEN_HOST=0.0.0.0
WEBHOOK_PORT=8080
LIGHTWEIGHT_MODE=true
ALLOWED_UPDATES=message,callback_query
STARTUP_WAITER_SYNC_LIMIT=500
ADMIN_IDS=123456789
ADMIN_PHONE_NUMBERS=+2348000000000,+2348111111111
WAITER_IDS=111111111,222222222
BOT_TIMEZONE=Africa/Lagos
CAFETERIA_NAME=Cafeteria 1

# KoraPay settings:
# - Use KORAPAY_MODE=mock for testing with test credentials (sk_test_*, pk_test_*)
# - Use KORAPAY_MODE=live with real production credentials only
# - If test credentials are detected in live mode, mock mode is auto-enabled for safety
KORAPAY_MODE=mock
KORAPAY_SECRET_KEY=sk_test_your_test_secret_key
KORAPAY_PUBLIC_KEY=pk_test_your_test_public_key
KORAPAY_CURRENCY=NGN
KORAPAY_CALLBACK_URL=https://example.com/korapay/callback
KORAPAY_INITIALIZE_URL=https://api.korapay.com/merchant/api/v1/charges/initialize

SERVICE_FEE_TOTAL=500
SERVICE_FEE_SPLIT_MODE=equal
DEFAULT_DELIVERY_ETA_MINUTES=25
HUMAN_READABLE_EXPORTS_ENABLED=true
PLACEHOLDER_IMAGE_URL=https://via.placeholder.com/1024x768.png?text=Food+Item
START_LOGO=assets/primechop-logo.png
SUPER_ADMIN_SECRET=replace_with_strong_admin_password

EXCEL_AUDIT_ENABLED=true
EXCEL_AUDIT_BACKEND=sqlite
EXCEL_AUDIT_FILE=primechop_audit.xlsx
EXCEL_AUDIT_SQLITE_DB=primechop.db
EXCEL_AUDIT_ASYNC_WRITES=true
EXCEL_AUDIT_FLUSH_INTERVAL_SECONDS=1.0
EXCEL_AUDIT_BATCH_SIZE=25
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_CREDENTIALS_FILE=
GOOGLE_SHEETS_ORDER_SHEET=OrdersAudit
GOOGLE_SHEETS_WAITER_SHEET=WaiterRegistry

# Prime assistant AI fallback (OpenAI-compatible endpoint)
PRIME_AI_ENABLED=true
PRIME_AI_API_KEY=
PRIME_AI_CHAT_URL=https://openrouter.ai/api/v1/chat/completions
PRIME_AI_MODEL=openai/gpt-4o-mini
PRIME_AI_TIMEOUT_SECONDS=20
